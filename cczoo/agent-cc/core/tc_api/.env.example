# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Docker/Image Configuration
DOCKER_REGISTRY=docker.io
DOCKER_REPOSITORY=<your docker hub account>

# File Storage Configuration
UPLOAD_DIR=./uploads
BUILD_DIR=./builds
LOGS_DIR=./logs

# External Tool Commands
DOCKER_CMD=docker
COSIGN_CMD=cosign
SYFT_CMD=syft
SKOPEO_CMD=skopeo
SKOPEO_SOURCE=docker-daemon
SKOPEO_DESTINATION=oci

# KBS Configuration
KBS_URL=http://127.0.0.1:8006/cdh/resource/default/image-decryption-keys/
KBS_ENDPOINT=/kbs/v0
KBS_CLIENT_CMD=kbs-client

# Sigstore Author Configuration
GIT_EMAIL=your-email@example.com

# TruCon Service Authentication
# Auto-generated if not set. All services must share the same token.
# TRUCON_SERVICE_TOKEN=

# Optional Proxy Configuration
# Keep both lowercase and uppercase for compatibility across tools.
http_proxy=
https_proxy=
no_proxy=127.0.0.1,localhost
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=127.0.0.1,localhost
